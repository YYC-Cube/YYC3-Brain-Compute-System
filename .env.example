# Environment Variables for YYC³ Brain Computer System
# Copy this file to .env.local and fill in your values

# ===========================================
# Sentry Error Monitoring Configuration
# ===========================================

# Sentry DSN (Data Source Name) - Get from https://sentry.io/settings/projects/
# Format: https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=

# Sentry Environment (development | staging | production)
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Performance Monitoring Sample Rate (0.0 - 1.0)
# Recommended: 1.0 for production, 0.1 for staging, 0.0 for development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Session Replay Sample Rate (0.0 - 1.0)
# Recommended: 1.0 for errors, 0.1 for all sessions
SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Profiling Sample Rate (0.0 - 1.0)
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ===========================================
# Application Configuration
# ===========================================

# API Base URL (leave empty for same-origin)
NEXT_PUBLIC_API_URL=

# Application Mode (development | production | test)
NODE_ENV=development

# Enable Mock API (true | false)
NEXT_PUBLIC_MOCK_MODE=true

# ===========================================
# Feature Flags
# ===========================================

# Enable Sentry monitoring
NEXT_PUBLIC_ENABLE_SENTRY=false

# Enable performance profiling
NEXT_PUBLIC_ENABLE_PROFILING=false

# Enable session replay (requires user consent in production)
NEXT_PUBLIC_ENABLE_REPLAY=false

# ===========================================
# Production Deployment Notes
# ===========================================

# 1. Set NEXT_PUBLIC_SENTRY_DSN to your actual Sentry DSN
# 2. Set NEXT_PUBLIC_SENTRY_ENVIRONMENT to 'production'
# 3. Increase SENTRY_TRACES_SAMPLE_RATE to 0.2-1.0 based on traffic
# 4. Set NEXT_PUBLIC_ENABLE_SENTRY=true
# 5. Review and adjust sample rates based on Sentry quota

# Example Production Configuration:
# NEXT_PUBLIC_SENTRY_DSN=https://yourKey@o0.ingest.sentry.io/yourProjectId
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.2
# NEXT_PUBLIC_ENABLE_SENTRY=true
