# YYC³ Brain Computer System 环境变量配置
# 复制此文件为 .env 并填写实际值
# 支持4种运行模式: development | production | staging | mock

# ===========================================
# API 配置 (可选 - 系统会自动检测环境)
# ===========================================

# API 基础地址 (留空则自动根据环境选择)
# - localhost → http://192.168.3.100:3118/api/v1 (本地开发)
# - brain.yyc3.vip → '' (Mock模式) 或 https://api.brain.yyc3.vip/api/v1
VITE_API_BASE_URL=

# WebSocket 地址 (留空则自动适配)
VITE_WS_URL=

# Mock 模式开关:
#   'auto'  - 自动检测 (推荐, GitHub Pages默认使用Mock)
#   'true'  - 强制Mock模式 (纯前端演示)
#   'false' - 强制连接真实API
VITE_API_TEST_MODE=auto

# ===========================================
# 应用配置
# ===========================================

VITE_APP_TITLE=YYC³ Brain Computer System
VITE_APP_VERSION=3.2.0
VITE_APP_PORT=3155

# ===========================================
# 认证配置
# ===========================================

VITE_AUTH_TOKEN_KEY=yyc3_access_token
VITE_AUTH_REFRESH_TOKEN_KEY=yyc3_refresh_token

# ===========================================
# 环境说明
# ===========================================
#
# 📋 运行模式自动检测逻辑:
#
# 1. development (本地开发)
#    - 触发条件: hostname = localhost / 127.0.0.1
#    - API地址: http://192.168.3.100:3118/api/v1
#    - 用途: 本地开发调试，连接内网后端
#
# 2. mock (模拟模式) ⭐ 推荐用于GitHub Pages
#    - 触发条件: VITE_API_TEST_MODE=true 或 GitHub Pages + auto
#    - API地址: 无 (使用前端Mock数据)
#    - 用途: 纯前端演示，无需后端服务
#
# 3. production (生产环境)
#    - 触发条件: 其他域名 或 VITE_API_TEST_MODE=false
#    - API地址: https://api.brain.yyc3.vip/api/v1
#    - 用途: 正式生产环境，连接真实API网关
#
# 4. staging (预发布)
#    - 触发条件: 手动设置 VITE_API_BASE_URL 为staging地址
#    - API地址: https://api-staging.brain.yyc3.vip/api/v1
#    - 用途: 预发布测试环境
#
# ===========================================
# 快速开始示例
# ===========================================
#
# 本地开发 (连接内网):
#   cp .env.example .env
#   # 使用默认配置即可
#   pnpm dev
#
# GitHub Pages部署 (Mock模式):
#   # 在GitHub仓库 Settings → Secrets 添加:
#   # VITE_API_TEST_MODE = true
#   # push到main分支即可自动部署
#
# 生产部署 (真实API):
#   # 设置环境变量:
#   # VITE_API_BASE_URL=https://your-api.com/api/v1
#   # VITE_API_TEST_MODE=false
#
# ===========================================
